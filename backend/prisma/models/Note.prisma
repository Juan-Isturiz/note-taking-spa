model Note {
  id         String     @id @default(uuid())
  title      String
  content    String
  isArchived Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  isActive   Boolean    @default(true)
  //Relations
  user       User       @relation(fields: [userId], references: [id])
  categories Category[]
  userId     String
}
